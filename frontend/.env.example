# API 서버 URL (개발환경)
NEXT_PUBLIC_API_URL=http://localhost:8000

# 사이트 URL (프로덕션에서 실제 도메인으로 변경)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 사이트 정보
NEXT_PUBLIC_SITE_NAME=허우적 배송분류 자동화 시스템
NEXT_PUBLIC_SITE_DESCRIPTION=당일배송, 새벽배송, 택배배송을 자동으로 분류하고 주소 매칭을 통해 배송 효율성을 높이는 전문 솔루션

# GA 추적 ID (선택사항)
# NEXT_PUBLIC_GA_ID=GA_MEASUREMENT_ID 